{
  "manifest_version": 3,
  "name": "LinkCheck",
  "version": "1.0.0",
  "description": "Scan any webpage for broken and redirected links. Highlights issues in-page and exports results.",
  "permissions": ["activeTab", "notifications", "scripting", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LinkCheck — Broken Link Scanner",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Open LinkCheck popup"
    }
  }
}
